# === Exchange (for live trading) ===
EXCHANGE_ID=binance
EXCHANGE_API_KEY=your-exchange-api-key
EXCHANGE_SECRET=your-exchange-secret

# === Trading Parameters ===
INITIAL_CAPITAL=100000
