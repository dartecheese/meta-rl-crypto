# === LLM Configuration ===
# Any OpenAI-compatible API (vLLM, Ollama, OpenAI, Together, etc.)
LLM_API_BASE=http://localhost:8000/v1
LLM_API_KEY=not-needed
LLM_MODEL=meta-llama/Llama-3.1-8B-Instruct

# === Data Sources ===
CMC_API_KEY=your-coinmarketcap-api-key
